{
  "name": "skeleton-theme",
  "version": "1.0.0-alpha.1",
  "private": true,
  "type": "module",
  "description": "A barebones, Vite compatible, starting point for developing Shopify themes.",
  "author": "Shopify Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shopify/skeleton-theme.git"
  },
  "bugs": "https://github.com/Shopify/skeleton-theme/issues",
  "keywords": [
    "shopify",
    "theme"
  ],
  "scripts": {
    "dev": "concurrently -rkP 'shopify theme dev {@}' 'vite'",
    "build": "vite build",
    "deploy": "pnpm run build && shopify theme push",
    "format": "prettier --write --cache .",
    "format-check": "prettier --check .",
    "lint": "eslint --cache ."
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@shopify/prettier-plugin-liquid": "^1.8.2",
    "@tailwindcss/vite": "^4.0.7",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.7",
    "vite": "^6.1.1",
    "vite-plugin-shopify": "^3.2.0"
  }
}
